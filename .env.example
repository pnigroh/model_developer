# ── ModelDev environment variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.
# Never commit .env to version control.

# Django secret key — generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames / IPs
# e.g.  ALLOWED_HOSTS=modeldev.example.com,www.modeldev.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Superuser created on first boot (idempotent)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com
